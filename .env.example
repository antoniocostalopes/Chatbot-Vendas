# ---------------------------------------------------------------------------
# Closr — variáveis de ambiente
# Copia este ficheiro para `.env` e preenche os valores reais.
# NUNCA faças commit do `.env` (já está no .gitignore).
# Na Vercel: Project Settings → Environment Variables (os mesmos nomes).
# ---------------------------------------------------------------------------

# ── OpenAI (motor de IA do bot) ────────────────────────────────────────────
# BYO key: cada cliente põe a SUA chave no painel (área Conta). Esta chave de
# plataforma é OPCIONAL e serve só de fallback para bots sem chave própria
# (ex.: o bot de demonstração). Podes deixar vazia se todos trouxerem a deles.
OPENAI_API_KEY=
# Modelo por defeito quando o bot não define um (override por bot na DB).
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Segredo para cifrar as chaves OpenAI dos clientes em repouso (AES-256-GCM).
# Se não definires, é derivado da SUPABASE_SERVICE_ROLE_KEY. Define um valor
# próprio e estável em produção (mudá-lo invalida as chaves já guardadas).
ENCRYPTION_KEY=

# ── Supabase (base de dados + auth) ────────────────────────────────────────
# Project Settings → API. A SERVICE_ROLE só é usada no servidor (/api); nunca
# a exponhas no frontend.
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase (frontend / painel admin) ─────────────────────────────────────
# Estas são públicas por natureza (anon key, protegida por RLS). O prefixo
# VITE_ é obrigatório para o Vite as expor ao browser.
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App ────────────────────────────────────────────────────────────────────
# URL pública onde a API está alojada (usada pelo embed.js gerado). Em
# desenvolvimento local podes deixar vazio (usa a mesma origem).
PUBLIC_BASE_URL=https://chatbot-vendas.vercel.app
